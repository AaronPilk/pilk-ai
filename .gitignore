# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
uv.lock
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg

# Node
node_modules/
dist/
dist-ssr/
.vite/
.turbo/
# CI uses `npm ci || npm install` so committing lockfiles isn't required;
# keep them out so local `npm install` during agent work doesn't dirty the
# tree.
package-lock.json
uv.lock

# Tauri (when added)
ui/src-tauri/target/

# Env & secrets
.env
.env.*
!.env.example
# Google OAuth client secrets — machine-local, never commit.
pilk-google-client.json
pilk-google-client*.json
*-google-client.json

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# Local runtime (should never be committed)
/PILK/
pilk.db
pilk.db-*
# Stray literal "~/" directory created when code accidentally uses
# "~/PILK" as a filesystem path without tilde expansion. Keep it
# out of git regardless of the underlying code bug.
/~/

# Logs
*.log
logs/
