# PILK daemon
PILK_HOME=~/PILK
PILK_HOST=127.0.0.1
PILK_PORT=7424
PILK_LOG_LEVEL=INFO

# Dashboard (used by Vite at build time)
VITE_PILK_API=http://127.0.0.1:7424
VITE_PILK_WS=ws://127.0.0.1:7424/ws

# Anthropic API — required to run plans end-to-end.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — optional planner provider. Routes LIGHT or any other tier
# to gpt-4o-mini / gpt-4.1 / etc. Get a key at
# https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Google Gemini — optional planner provider, uses the OpenAI-
# compatible endpoint at generativelanguage.googleapis.com. Good
# default for LIGHT (gemini-2.5-flash is fast + cheap + huge context).
# Get a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# xAI Grok — optional planner provider. Grok 4 Fast is a capable
# alternative for LIGHT/STANDARD reasoning. Get a key at
# https://console.x.ai.
XAI_API_KEY=

# Orchestrator tuning (optional)
PILK_PLAN_MAX_TURNS=12
PILK_SHELL_TIMEOUT_S=30
PILK_COST_PREFLIGHT_ENABLED=true
PILK_COST_PREFLIGHT_APPROVAL_USD=2.00

# ── Supabase (foundation only; optional) ──────────────────────────
# PILK still runs identically when these are unset. They exist so
# future batches (auth, workspace membership, storage) have somewhere
# to land. Service role key is server-only — never expose in the UI.
# See docs/supabase.md for the full setup flow.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MASTER_ADMIN_EMAIL=
