# PILK dashboard — Vite env.
#
# Leaving these blank keeps the UI in *local mode*: no Supabase client,
# no bearer tokens, and API calls fall back to 127.0.0.1:7424 (the
# laptop-local pilkd). This is the developer default — just
# `npm run dev` and the pre-cloud workflow works unchanged.
#
# Set these during Cloudflare Pages build (app.pilk.ai) to flip into
# *cloud mode*: Supabase session becomes required, bearer tokens are
# attached to every pilkd request, and no session → redirect to the
# portal sign-in page.

# Supabase project creds (same project as the portal — anon key is safe
# in the browser, RLS on the backend does the real enforcement).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Hosted pilkd (Railway) for cloud mode. In local dev, leave blank.
VITE_PILK_API=
VITE_PILK_WS=

# Portal origin for sign-out redirects. Only needs overriding on
# preview deploys; production defaults to https://pilk.ai.
VITE_PORTAL_URL=
